        "h": 8,
        "w": 8,
        "x": 8,
        "y": 18
      },
      "id": 6,
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "jvm_memory_used_bytes{job=~\"$job\", area=\"heap\"}",
          "legendFormat": "Heap Memory Used",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "jvm_memory_max_bytes{job=~\"$job\", area=\"heap\"}",
          "legendFormat": "Heap Memory Max",
          "refId": "B"
        }
      ],
      "title": "JVM Heap Memory",
      "type": "timeseries"
