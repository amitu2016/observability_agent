      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "Prometheus"
          },
          "editorMode": "code",
          "expr": "process_cpu_usage{job=~\"$job\"}",
          "legendFormat": "JVM CPU Usage",
          "refId": "A"
